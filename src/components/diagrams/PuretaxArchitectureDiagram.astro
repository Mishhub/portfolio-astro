---
/**
 * Architecture diagram for the PureTax case study.
 *
 * Diagrams live as standalone .astro components (not inline in MDX) so they can
 * use scoped <style>, stay zero-JS, and adapt to light/dark via currentColor.
 */
---

<svg
  viewBox="0 0 820 380"
  class="diagram mx-auto h-auto w-full max-w-3xl text-foreground"
  role="img"
  aria-label="PureTax architecture: multiple accounting tenants call a Django + DRF API that scopes every query to a tenant in PostgreSQL. The API syncs financial data from the QuickBooks Online API and enqueues work on Redis, where Celery workers run scheduled monthly report generation. Workers render reports through an export pipeline into PDF, XLSX and CSV with charts."
>
  <defs>
    <marker id="px-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" fill="currentColor" fill-opacity="0.5"></path>
    </marker>
  </defs>

  <rect class="box" x="24" y="150" width="120" height="62" rx="10"></rect>
  <text class="lbl" x="84" y="176" text-anchor="middle">Tenants</text>
  <text class="sub" x="84" y="194" text-anchor="middle">accounting firms</text>

  <rect class="box accent" x="200" y="142" width="180" height="78" rx="10"></rect>
  <text class="lbl" x="290" y="170" text-anchor="middle">Django · DRF</text>
  <text class="sub" x="290" y="188" text-anchor="middle">multi-tenant API</text>
  <text class="sub" x="290" y="206" text-anchor="middle">per-tenant scoping</text>

  <rect class="store" x="200" y="280" width="180" height="50" rx="9"></rect>
  <text class="lbl" x="290" y="304" text-anchor="middle">PostgreSQL</text>
  <text class="sub" x="290" y="320" text-anchor="middle">tenant-isolated</text>

  <rect class="box" x="560" y="64" width="232" height="52" rx="10"></rect>
  <text class="lbl" x="580" y="88">QuickBooks Online</text>
  <text class="sub" x="580" y="105">financial sync · API</text>

  <rect class="store" x="440" y="150" width="160" height="62" rx="10"></rect>
  <text class="lbl" x="520" y="176" text-anchor="middle">Redis</text>
  <text class="sub" x="520" y="194" text-anchor="middle">broker · cache</text>

  <rect class="box" x="640" y="150" width="152" height="62" rx="10"></rect>
  <text class="lbl" x="716" y="176" text-anchor="middle">Celery workers</text>
  <text class="sub" x="716" y="194" text-anchor="middle">monthly reporting</text>

  <rect class="box" x="440" y="280" width="180" height="62" rx="10"></rect>
  <text class="lbl" x="530" y="306" text-anchor="middle">Export pipeline</text>
  <text class="sub" x="530" y="324" text-anchor="middle">render · charts</text>

  <rect class="store" x="652" y="280" width="140" height="62" rx="10"></rect>
  <text class="lbl" x="722" y="306" text-anchor="middle">Reports</text>
  <text class="sub" x="722" y="324" text-anchor="middle">PDF · XLSX · CSV</text>

  <path class="edge" d="M144 181H198" marker-end="url(#px-arrow)"></path>
  <path class="edge" d="M290 220V278" marker-end="url(#px-arrow)"></path>
  <path class="edge" d="M380 168 Q470 120 558 96" marker-end="url(#px-arrow)"></path>
  <path class="edge" d="M380 188H438" marker-end="url(#px-arrow)"></path>
  <path class="edge" d="M600 181H638" marker-end="url(#px-arrow)"></path>
  <path class="edge" d="M716 212V250 H530 V278" marker-end="url(#px-arrow)"></path>
  <path class="edge" d="M620 311H650" marker-end="url(#px-arrow)"></path>
</svg>

<style>
  .box {
    fill: color-mix(in oklch, currentColor 6%, transparent);
    stroke: currentColor;
    stroke-opacity: 0.35;
    stroke-width: 1.5;
  }
  .box.accent {
    fill: color-mix(in oklch, var(--brand) 12%, transparent);
    stroke: var(--brand);
    stroke-opacity: 0.5;
  }
  .store {
    fill: color-mix(in oklch, currentColor 10%, transparent);
    stroke: currentColor;
    stroke-opacity: 0.4;
    stroke-width: 1.5;
  }
  .lbl {
    fill: currentColor;
    font:
      600 13px ui-sans-serif,
      system-ui;
  }
  .sub {
    fill: currentColor;
    fill-opacity: 0.6;
    font:
      11px ui-monospace,
      monospace;
  }
  .edge {
    stroke: currentColor;
    stroke-opacity: 0.4;
    stroke-width: 1.5;
    fill: none;
  }
</style>

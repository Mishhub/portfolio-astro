---
/**
 * Architecture diagram for the Spovio HRMS case study.
 *
 * Diagrams live as standalone .astro components (not inline in MDX) so they can
 * use scoped <style>, stay zero-JS, and adapt to light/dark via currentColor.
 */
---

<svg
  viewBox="0 0 820 360"
  class="diagram mx-auto h-auto w-full max-w-3xl text-foreground"
  role="img"
  aria-label="Spovio architecture: a React client calls a Django REST API backed by PostgreSQL. The API stores organization and user files in AWS S3 and enqueues work on Redis, which Celery workers and a Celery beat scheduler consume to accrue time, run monthly payroll and send notifications. Workers deliver HR alerts and approvals through email and SMS providers."
>
  <defs>
    <marker id="sp-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" fill="currentColor" fill-opacity="0.5"></path>
    </marker>
  </defs>

  <rect class="box" x="24" y="150" width="116" height="58" rx="10"></rect>
  <text class="lbl" x="82" y="176" text-anchor="middle">React Client</text>
  <text class="sub" x="82" y="193" text-anchor="middle">SPA · Redux</text>

  <rect class="box accent" x="190" y="142" width="170" height="74" rx="10"></rect>
  <text class="lbl" x="275" y="170" text-anchor="middle">Django API</text>
  <text class="sub" x="275" y="188" text-anchor="middle">DRF · REST</text>
  <text class="sub" x="275" y="204" text-anchor="middle">time-off · payroll</text>

  <rect class="store" x="60" y="270" width="120" height="46" rx="9"></rect>
  <text class="lbl" x="120" y="293" text-anchor="middle">AWS S3</text>
  <text class="sub" x="120" y="308" text-anchor="middle">file storage</text>

  <rect class="store" x="200" y="270" width="120" height="46" rx="9"></rect>
  <text class="lbl" x="260" y="293" text-anchor="middle">PostgreSQL</text>
  <text class="sub" x="260" y="308" text-anchor="middle">core data</text>

  <rect class="store" x="340" y="270" width="140" height="46" rx="9"></rect>
  <text class="lbl" x="410" y="293" text-anchor="middle">Redis · broker</text>
  <text class="sub" x="410" y="308" text-anchor="middle">cache · queue</text>

  <rect class="box accent" x="560" y="262" width="220" height="58" rx="10"></rect>
  <text class="lbl" x="578" y="288">Celery workers</text>
  <text class="sub" x="578" y="304">beat · accrual · payroll</text>

  <rect class="box" x="560" y="74" width="220" height="50" rx="10"></rect>
  <text class="lbl" x="578" y="98">Email provider</text>
  <text class="sub" x="578" y="114">HR alerts · approvals</text>

  <rect class="box" x="560" y="150" width="220" height="50" rx="10"></rect>
  <text class="lbl" x="578" y="174">SMS provider</text>
  <text class="sub" x="578" y="190">notifications</text>

  <path class="edge" d="M140 179H188" marker-end="url(#sp-arrow)"></path>
  <path class="edge" d="M240 216V250 H120 V268" marker-end="url(#sp-arrow)"></path>
  <path class="edge" d="M275 216V268" marker-end="url(#sp-arrow)"></path>
  <path class="edge" d="M310 216 Q380 240 410 268" marker-end="url(#sp-arrow)"></path>
  <path class="edge" d="M480 293H558" marker-end="url(#sp-arrow)"></path>
  <path class="edge" d="M670 262 Q670 200 670 124" marker-end="url(#sp-arrow)"></path>
  <path class="edge" d="M640 262 Q620 230 600 202" marker-end="url(#sp-arrow)"></path>
</svg>

<style>
  .box {
    fill: color-mix(in oklch, currentColor 6%, transparent);
    stroke: currentColor;
    stroke-opacity: 0.35;
    stroke-width: 1.5;
  }
  .box.accent {
    fill: color-mix(in oklch, var(--brand) 12%, transparent);
    stroke: var(--brand);
    stroke-opacity: 0.5;
  }
  .store {
    fill: color-mix(in oklch, currentColor 10%, transparent);
    stroke: currentColor;
    stroke-opacity: 0.4;
    stroke-width: 1.5;
  }
  .lbl {
    fill: currentColor;
    font:
      600 13px ui-sans-serif,
      system-ui;
  }
  .sub {
    fill: currentColor;
    fill-opacity: 0.6;
    font:
      11px ui-monospace,
      monospace;
  }
  .edge {
    stroke: currentColor;
    stroke-opacity: 0.4;
    stroke-width: 1.5;
    fill: none;
  }
</style>

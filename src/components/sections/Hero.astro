---
import { Icon } from "astro-icon/components";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import Avatar from "@/components/ui/Avatar.astro";
import Badge from "@/components/ui/Badge.astro";
import Social from "@/components/layout/Social.astro";
import { SITE, RESUME_PATH } from "@/config/site";
import { DOMAINS } from "@/data/skills";

const quickFacts = [
  { icon: "lucide:git-branch", label: "6+ years shipping full-stack products" },
  { icon: "lucide:server", label: "Backend · distributed systems · Web3" },
  { icon: "lucide:map-pin", label: SITE.location },
];
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-grid mask-radial-fade opacity-[0.35]"></div>
  <div
    class="pointer-events-none absolute -top-40 left-1/2 -z-10 h-[32rem] w-[32rem] -translate-x-1/2 rounded-full bg-brand/10 blur-3xl"
  >
  </div>

  <Container size="wide" class="pb-16 pt-20 sm:pb-24 sm:pt-28">
    <div class="grid items-center gap-12 lg:grid-cols-[1.5fr_1fr]">
      <div data-reveal>
        <Badge variant="brand" class="mb-6">
          <span class="relative flex size-2">
            <span class="absolute inline-flex size-full animate-ping rounded-full bg-brand opacity-60"></span>
            <span class="relative inline-flex size-2 rounded-full bg-brand"></span>
          </span>
          {SITE.availability}
        </Badge>

        <h1 class="text-4xl font-semibold tracking-tight text-foreground text-balance sm:text-5xl lg:text-6xl">
          {SITE.name}
        </h1>
        <p class="mt-3 text-lg font-medium text-muted-foreground sm:text-xl">
          {SITE.role}
        </p>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-foreground/80 text-pretty">
          I design and build <span class="text-foreground">full-stack web and Web3 platforms</span> —
          distributed backend services, authentication systems and the interfaces on top of them.
          6+ years across FinTech, Web3 and high-traffic products.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <Button href={RESUME_PATH} variant="primary" size="lg">
            <Icon name="lucide:arrow-down-to-line" />
            Download Résumé
          </Button>
          <Button href="/projects" variant="outline" size="lg">
            View Work
            <Icon name="lucide:arrow-right" />
          </Button>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-3">
          <Social />
          <span class="hidden h-5 w-px bg-border sm:block"></span>
          <ul class="flex flex-wrap gap-2">
            {DOMAINS.map((d) => <li><Badge size="sm">{d}</Badge></li>)}
          </ul>
        </div>
      </div>

      <div data-reveal style="--reveal-delay:120ms" class="lg:justify-self-end">
        <div class="relative max-w-sm rounded-3xl border border-border bg-card/60 p-6 backdrop-blur-sm">
          <div class="flex items-center gap-4">
            <Avatar size="lg" />
            <div>
              <p class="font-semibold tracking-tight text-foreground">{SITE.name}</p>
              <p class="text-sm text-muted-foreground">{SITE.handle}</p>
            </div>
          </div>
          <ul class="mt-6 space-y-3">
            {
              quickFacts.map((fact) => (
                <li class="flex items-center gap-3 text-sm text-muted-foreground">
                  <Icon name={fact.icon} class="size-4 shrink-0 text-brand" aria-hidden="true" />
                  <span>{fact.label}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <a
      href="#what-i-bring"
      class="mx-auto mt-16 flex w-fit flex-col items-center gap-2 text-xs text-muted-foreground transition-colors hover:text-foreground"
      aria-label="Scroll to content"
    >
      <span class="uppercase tracking-[0.16em]">Scroll</span>
      <Icon name="lucide:chevron-down" class="size-4 motion-safe:animate-bounce" aria-hidden="true" />
    </a>
  </Container>
</section>

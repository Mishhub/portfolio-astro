---
import Container from "@/components/ui/Container.astro";
import { TRUSTED_TECH } from "@/data/home";
---

<section class="border-y border-border bg-subtle/40 py-10" aria-label="Core technologies">
  <Container size="wide">
    <p class="text-center text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">
      Day-to-day toolkit
    </p>
    <ul
      class="mt-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm font-medium text-muted-foreground"
    >
      {
        TRUSTED_TECH.map((tech) => (
          <li class="font-mono transition-colors hover:text-foreground">{tech}</li>
        ))
      }
    </ul>
  </Container>
</section>

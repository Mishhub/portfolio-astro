---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.tsx";
import MobileNav from "./MobileNav.tsx";
import Button from "@/components/ui/Button.astro";
import { NAV, RESUME_PATH } from "@/config/site";
import { cn } from "@/lib/utils";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const primary = NAV.filter((item) => !item.secondary);

const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(`${href}/`);
---

<header id="site-header" class="group sticky top-0 z-40">
  {/*
    Frosted-glass background lives on this child, NOT the <header>. Putting
    `backdrop-filter` on the header itself would make it the containing block for
    the mobile nav's `position: fixed` drawer, trapping it in the header box.
    Isolating the filter here keeps the drawer anchored to the viewport.
  */}
  <div
    class="pointer-events-none absolute inset-0 -z-10 border-b border-transparent transition-colors duration-300 group-data-[scrolled]:border-border group-data-[scrolled]:bg-background/80 group-data-[scrolled]:backdrop-blur-md"
    aria-hidden="true"
  >
  </div>
  <div class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between gap-4 px-5 sm:px-6 lg:px-8">
    <Logo class="min-w-0 shrink" markOnly />

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          primary.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cn(
                  "relative rounded-md px-3 py-2 text-sm font-medium transition-colors",
                  isActive(item.href)
                    ? "text-foreground"
                    : "text-muted-foreground hover:text-foreground",
                )}
              >
                {item.label}
                {isActive(item.href) && (
                  <span class="absolute inset-x-3 -bottom-px h-px bg-foreground" aria-hidden="true" />
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-1">
      <ThemeToggle client:idle transition:persist />
      <Button href={RESUME_PATH} variant="outline" size="sm" class="hidden md:inline-flex">
        Résumé
      </Button>
      <MobileNav client:idle items={NAV} resumePath={RESUME_PATH} />
    </div>
  </div>
</header>

<script>
  // Solidify the header once the page scrolls past the hero edge.
  // Re-query the element on every call: View Transitions swap in a fresh
  // <header> on navigation, so a cached reference would go stale and the
  // frosted-glass background would stop appearing after the first page.
  const onScroll = () => {
    const header = document.getElementById("site-header");
    if (!header) return;
    header.toggleAttribute("data-scrolled", window.scrollY > 8);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
  // Re-evaluate after each navigation (the new header starts without the
  // attribute, and the scroll position may already be past the threshold).
  document.addEventListener("astro:after-swap", onScroll);
</script>

---
import { cn } from "@/lib/utils";

/** Monospace technology keyword chip — used for stacks and tag lists. */
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className } = Astro.props;

const base = cn(
  "inline-flex items-center rounded-md border border-border bg-subtle px-2 py-1 font-mono text-xs text-muted-foreground",
  href && "transition-colors hover:border-foreground/20 hover:text-foreground",
  className,
);
---

{
  href ? (
    <a href={href} class={base}>
      <slot />
    </a>
  ) : (
    <span class={base}>
      <slot />
    </span>
  )
}

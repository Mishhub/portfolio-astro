---
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";

/** Small status/label pill. Use Tag.astro for tech keywords. */
const badge = cva(
  "inline-flex items-center gap-1.5 rounded-full border font-medium leading-none",
  {
    variants: {
      variant: {
        default: "border-border bg-muted text-muted-foreground",
        brand: "border-brand/25 bg-brand/10 text-brand",
        success: "border-success/25 bg-success/10 text-success",
        outline: "border-border bg-transparent text-foreground",
      },
      size: {
        sm: "px-2 py-0.5 text-[0.7rem]",
        md: "px-2.5 py-1 text-xs",
      },
    },
    defaultVariants: { variant: "default", size: "md" },
  },
);

type Props = VariantProps<typeof badge> & { class?: string };
const { variant, size, class: className } = Astro.props;
---

<span class={cn(badge({ variant, size }), className)}>
  <slot />
</span>

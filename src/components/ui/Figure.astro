---
import { cn } from "@/lib/utils";

/**
 * Framed figure for diagrams, screenshots and inline SVG. Architecture and
 * sequence diagrams are authored as inline SVG/markup inside this frame so they
 * stay crisp, themeable and ship zero client JS.
 */
interface Props {
  caption?: string;
  /** Subtle dotted backdrop suited to system diagrams. */
  diagram?: boolean;
  class?: string;
}
const { caption, diagram = false, class: className } = Astro.props;
---

<figure class={cn("my-8", className)}>
  <div
    class={cn(
      "overflow-x-auto rounded-2xl border border-border bg-card p-5 sm:p-8",
      diagram && "bg-subtle",
    )}
  >
    <slot />
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-center text-sm text-muted-foreground">{caption}</figcaption>
    )
  }
</figure>

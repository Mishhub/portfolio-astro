---
import { cn } from "@/lib/utils";

/** Small uppercase label with a brand dot — sits above section headings. */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<span
  class={cn(
    "inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground",
    className,
  )}
>
  <span class="size-1.5 rounded-full bg-brand" aria-hidden="true"></span>
  <slot />
</span>

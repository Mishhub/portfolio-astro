---
import type { HTMLTag, Polymorphic } from "astro/types";
import { cn } from "@/lib/utils";

/** Centered max-width wrapper with consistent gutters. */
type Props<Tag extends HTMLTag = "div"> = Polymorphic<{ as: Tag }> & {
  size?: "default" | "prose" | "wide";
};

const { as: Tag = "div", size = "default", class: className, ...rest } = Astro.props;

const sizes = {
  default: "max-w-6xl",
  prose: "max-w-[var(--container-prose)]",
  wide: "max-w-7xl",
};
---

<Tag class={cn("mx-auto w-full px-5 sm:px-6 lg:px-8", sizes[size], className)} {...rest}>
  <slot />
</Tag>

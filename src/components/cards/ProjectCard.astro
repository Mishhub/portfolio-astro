---
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import Card from "@/components/ui/Card.astro";
import Tag from "@/components/ui/Tag.astro";
import Badge from "@/components/ui/Badge.astro";
import { cn } from "@/lib/utils";

interface Props {
  project: CollectionEntry<"projects">;
  /** Cap the number of tech tags shown. */
  maxTech?: number;
  class?: string;
}
const { project, maxTech = 5, class: className } = Astro.props;
const { data, id } = project;

const statusLabel: Record<string, string> = {
  live: "Live",
  wip: "In progress",
  archived: "Archived",
  internal: "Internal",
};

const tech = data.technologies.slice(0, maxTech);
const extra = data.technologies.length - tech.length;
---

<Card href={`/projects/${id}`} class={cn("flex h-full flex-col", className)}>
  <div class="flex items-start justify-between gap-4">
    <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
      {data.domain && <span class="font-medium text-foreground/70">{data.domain}</span>}
      <span>{data.year}</span>
    </div>
    <Badge variant={data.status === "live" ? "success" : "default"} size="sm">
      {statusLabel[data.status]}
    </Badge>
  </div>

  <h3
    class="mt-4 text-lg font-semibold tracking-tight text-foreground transition-colors group-hover:text-brand"
  >
    {data.title}
  </h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">{data.summary}</p>

  <ul class="mt-5 flex flex-wrap gap-1.5">
    {tech.map((t) => <li><Tag>{t}</Tag></li>)}
    {extra > 0 && <li><Tag>+{extra}</Tag></li>}
  </ul>

  <div
    class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-foreground/70 transition-colors group-hover:text-foreground"
  >
    View project
    <Icon
      name="lucide:arrow-right"
      class="size-4 transition-transform group-hover:translate-x-0.5"
      aria-hidden="true"
    />
  </div>
</Card>

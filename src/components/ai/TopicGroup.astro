---
import Tag from "@/components/ui/Tag.astro";
import type { Topic } from "@/data/ai-journey";

/**
 * A labelled cluster of topic tags for one stage of the learning arc
 * (foundations / core / agents / applied) on the AI Engineering page.
 */
interface Props {
  label: string;
  topics: Topic[];
}

const { label, topics } = Astro.props;
---

<div class="rounded-2xl border border-border bg-card p-6">
  <h3 class="text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">{label}</h3>
  <ul class="mt-4 flex flex-wrap gap-2">
    {topics.map((t) => <li><Tag>{t.name}</Tag></li>)}
  </ul>
</div>

---
import { Icon } from "astro-icon/components";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Tag from "@/components/ui/Tag.astro";
import { cn, formatRange, durationBetween } from "@/lib/utils";
import type { ExperienceEntry } from "@/data/experience";

/**
 * One node on the experience timeline: a dot on the left rail and a company
 * card offset to the right. The card is a native <details>/<summary> — the
 * summary row (company / role / dates) is always visible; expanding reveals
 * responsibilities, impact and the tech stack. Zero client JS.
 */
interface Props {
  entry: ExperienceEntry;
  /** Expand the first/most-recent role by default. */
  open?: boolean;
}

const { entry, open = false } = Astro.props;
const { company, context, role, location, start, end, summary, responsibilities, impact, stack } =
  entry;
const isCurrent = entry.current ?? end === null;
const range = formatRange(start, end);
const duration = durationBetween(start, end);
---

<div class="relative pl-10 sm:pl-14">
  {/* Rail dot — aligned to the shared rail line drawn by the page. */}
  <span
    class="absolute left-0 top-1.5 flex size-7 -translate-x-1/2 items-center justify-center sm:top-2"
    aria-hidden="true"
  >
    <span
      class={cn(
        "size-3 rounded-full ring-4 ring-background",
        isCurrent ? "bg-brand" : "bg-muted-foreground/40",
      )}
    >
    </span>
    {
      isCurrent && (
        <span class="absolute inline-flex size-3 animate-ping rounded-full bg-brand/50 motion-reduce:hidden" />
      )
    }
  </span>

  <Card as="details" interactive class="group/item p-0" {...open ? { open: true } : {}}>
    <summary
      class="flex cursor-pointer list-none flex-col gap-4 rounded-2xl p-5 outline-none focus-visible:ring-2 focus-visible:ring-ring sm:flex-row sm:items-start sm:justify-between sm:p-6 [&::-webkit-details-marker]:hidden"
    >
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-semibold tracking-tight text-foreground">{company}</h3>
          {isCurrent && <Badge variant="brand" size="sm">Current</Badge>}
        </div>
        <p class="mt-1 text-sm font-medium text-foreground">{role}</p>
        <p class="mt-0.5 text-xs text-muted-foreground">{context}</p>
      </div>

      <div class="flex shrink-0 items-start justify-between gap-3 sm:flex-col sm:items-end sm:text-right">
        <div>
          <p class="font-mono text-xs text-muted-foreground">{range}</p>
          <p class="mt-1 flex items-center gap-1.5 text-xs text-muted-foreground sm:justify-end">
            <Icon name="lucide:clock" class="size-3.5 opacity-70" aria-hidden="true" />
            {duration}
            <span class="opacity-40">·</span>
            <Icon name="lucide:map-pin" class="size-3.5 opacity-70" aria-hidden="true" />
            {location}
          </p>
        </div>
        <Icon
          name="lucide:chevron-down"
          class="mt-0.5 size-5 shrink-0 text-muted-foreground transition-transform duration-300 group-open/item:rotate-180"
          aria-hidden="true"
        />
      </div>
    </summary>

    <div class="border-t border-border px-5 pb-6 pt-5 sm:px-6">
      <p class="text-sm leading-relaxed text-muted-foreground text-pretty">{summary}</p>

      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        <div>
          <h4
            class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground"
          >
            <Icon name="lucide:list-checks" class="size-4 text-foreground/70" aria-hidden="true" />
            Responsibilities
          </h4>
          <ul class="mt-3 space-y-2.5">
            {
              responsibilities.map((item) => (
                <li class="flex gap-2.5 text-sm leading-relaxed text-muted-foreground">
                  <Icon
                    name="lucide:dot"
                    class="mt-0.5 size-4 shrink-0 text-foreground/40"
                    aria-hidden="true"
                  />
                  <span class="text-pretty">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h4
            class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground"
          >
            <Icon name="lucide:trending-up" class="size-4 text-brand" aria-hidden="true" />
            Impact
          </h4>
          <ul class="mt-3 space-y-2.5">
            {
              impact.map((item) => (
                <li class="flex gap-2.5 text-sm leading-relaxed text-muted-foreground">
                  <Icon
                    name="lucide:check"
                    class="mt-0.5 size-4 shrink-0 text-brand"
                    aria-hidden="true"
                  />
                  <span class="text-pretty">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mt-6">
        <h4
          class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground"
        >
          <Icon name="lucide:layers" class="size-4 text-foreground/70" aria-hidden="true" />
          Stack
        </h4>
        <ul class="mt-3 flex flex-wrap gap-2">
          {
            stack.map((tech) => (
              <li>
                <Tag>{tech}</Tag>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Card>
</div>

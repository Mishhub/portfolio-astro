---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/layout/PageHeader.astro";
import Breadcrumbs from "@/components/layout/Breadcrumbs.astro";
import Container from "@/components/ui/Container.astro";
import Card from "@/components/ui/Card.astro";
import Tag from "@/components/ui/Tag.astro";
import Badge from "@/components/ui/Badge.astro";
import Reveal from "@/components/ui/Reveal.astro";
import ProjectCard from "@/components/cards/ProjectCard.astro";
import ContactCTA from "@/components/sections/ContactCTA.astro";
import { getSortedProjects } from "@/lib/content";
import { personSchema, breadcrumbSchema } from "@/lib/seo";

const projects = await getSortedProjects();
const [hero, ...rest] = projects;

const origin = Astro.site!.origin;
const crumbs = [
  { name: "Home", href: "/" },
  { name: "Projects", href: "/projects" },
];
const jsonLd = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: new URL(c.href, origin).href }))),
  personSchema(origin),
];

const statusLabel: Record<string, string> = {
  live: "Live",
  wip: "In progress",
  archived: "Archived",
  internal: "Internal",
};
---

<BaseLayout
  title="Projects — Systems I've Designed and Shipped"
  description="A selection of production systems I've architected and built — event-driven backends, platforms and developer tooling across FinTech and authentication."
  jsonLd={jsonLd}
>
  <PageHeader
    eyebrow="Projects"
    title="Systems I've designed and shipped"
    lead="Production work spanning distributed backends, platforms and the interfaces on top of them. Each entry links through to the problem, the architecture and what I owned."
  >
    <Breadcrumbs slot="breadcrumbs" items={crumbs} class="mb-2" />
  </PageHeader>

  <Container size="wide" class="py-16 sm:py-20">
    {
      projects.length === 0 ? (
        <p class="text-muted-foreground">Projects are being written up — check back soon.</p>
      ) : (
        <div class="space-y-12">
          {hero && (
            <Reveal>
              <Card
                href={`/projects/${hero.id}`}
                as="article"
                class="flex flex-col gap-6 lg:flex-row lg:items-stretch lg:gap-10 lg:p-8"
              >
                <div class="flex flex-1 flex-col">
                  <div class="flex flex-wrap items-center gap-2.5 text-xs text-muted-foreground">
                    <Badge variant="brand" size="sm">
                      Featured
                    </Badge>
                    {hero.data.domain && (
                      <span class="font-medium text-foreground/70">{hero.data.domain}</span>
                    )}
                    <span aria-hidden="true">·</span>
                    <span>{hero.data.year}</span>
                    <span aria-hidden="true">·</span>
                    <Badge variant={hero.data.status === "live" ? "success" : "default"} size="sm">
                      {statusLabel[hero.data.status]}
                    </Badge>
                  </div>

                  <h2 class="mt-4 text-2xl font-semibold tracking-tight text-foreground transition-colors group-hover:text-brand sm:text-3xl">
                    {hero.data.title}
                  </h2>
                  <p class="mt-3 max-w-2xl text-base leading-relaxed text-muted-foreground">
                    {hero.data.summary}
                  </p>

                  {hero.data.technologies.length > 0 && (
                    <ul class="mt-6 flex flex-wrap gap-1.5">
                      {hero.data.technologies.slice(0, 8).map((t) => (
                        <li>
                          <Tag>{t}</Tag>
                        </li>
                      ))}
                    </ul>
                  )}

                  <div class="mt-auto pt-7 inline-flex items-center gap-1.5 text-sm font-medium text-foreground/70 transition-colors group-hover:text-foreground">
                    View project
                    <Icon
                      name="lucide:arrow-right"
                      class="size-4 transition-transform group-hover:translate-x-0.5"
                      aria-hidden="true"
                    />
                  </div>
                </div>

                {hero.data.role && (
                  <div class="shrink-0 self-start rounded-xl border border-border bg-subtle p-5 lg:w-56">
                    <p class="text-xs uppercase tracking-[0.16em] text-muted-foreground">My role</p>
                    <p class="mt-2 text-sm font-medium text-foreground">{hero.data.role}</p>
                  </div>
                )}
              </Card>
            </Reveal>
          )}

          {rest.length > 0 && (
            <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {rest.map((project, i) => (
                <li class="flex">
                  <Reveal delay={i * 80} class="flex w-full">
                    <ProjectCard project={project} />
                  </Reveal>
                </li>
              ))}
            </ul>
          )}
        </div>
      )
    }
  </Container>

  <ContactCTA />
</BaseLayout>

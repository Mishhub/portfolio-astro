---
import { getCollection } from "astro:content";
import ArticleLayout from "@/layouts/ArticleLayout.astro";

export const getStaticPaths = (async () => {
  const articles = await getCollection("articles", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );

  // Newest first — the published order used everywhere else.
  const sorted = [...articles].sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );

  return sorted.map((entry, i) => {
    const related = sorted
      .filter((a) => a.id !== entry.id && a.data.category === entry.data.category)
      .slice(0, 3);

    return {
      params: { slug: entry.id },
      props: {
        entry,
        related,
        // Reading order: prev = older, next = newer (matches the sort).
        prev: sorted[i + 1],
        next: sorted[i - 1],
      },
    };
  });
}) satisfies import("astro").GetStaticPaths;

const { entry, related, prev, next } = Astro.props;
---

<ArticleLayout entry={entry} related={related} prev={prev} next={next} />

---
import { Icon } from "astro-icon/components";
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Card from "@/components/ui/Card.astro";
import Container from "@/components/ui/Container.astro";
import Breadcrumbs from "@/components/layout/Breadcrumbs.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import Stat from "@/components/ui/Stat.astro";
import Tag from "@/components/ui/Tag.astro";
import Prose from "@/components/ui/Prose.astro";
import Toc from "@/components/case-studies/Toc.astro";
import ContactCTA from "@/components/sections/ContactCTA.astro";
import { breadcrumbSchema, articleSchema } from "@/lib/seo";

export const getStaticPaths = (async () => {
  const items = await getCollection("caseStudies");
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}) satisfies import("astro").GetStaticPaths;

interface Props {
  entry: CollectionEntry<"caseStudies">;
}
const { entry } = Astro.props;
const { data } = entry;
const { Content, headings } = await render(entry);

const origin = Astro.site!.origin;
const url = `${origin}/case-studies/${entry.id}`;

// Derive a sensible ISO publish date from the free-form `year` (e.g.
// "2023 — 2024" -> the later year). Falls back to the current year.
const years = data.year.match(/\d{4}/g) ?? [];
const publishYear = years.length ? years[years.length - 1] : String(new Date().getUTCFullYear());
const datePublished = `${publishYear}-01-01`;

const jsonLd = [
  breadcrumbSchema([
    { name: "Home", url: `${origin}/` },
    { name: "Case Studies", url: `${origin}/case-studies` },
    { name: data.title, url },
  ]),
  articleSchema(origin, {
    title: data.title,
    description: data.description,
    url,
    datePublished,
    tags: data.tags,
  }),
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  publishedTime={datePublished}
  tags={data.tags}
  jsonLd={jsonLd}
>
  <Container size="wide" class="py-12 sm:py-16">
    <Breadcrumbs
      items={[
        { name: "Home", href: "/" },
        { name: "Case Studies", href: "/case-studies" },
        { name: data.title },
      ]}
    />

    <header class="mt-8 max-w-3xl">
      <Eyebrow>{data.problemSpace}</Eyebrow>
      <h1
        class="mt-4 text-4xl font-semibold tracking-tight text-foreground text-balance sm:text-5xl"
      >
        {data.title}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground text-pretty">
        {data.description}
      </p>

      <dl class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-muted-foreground">
        <div class="flex items-center gap-1.5">
          <Icon name="lucide:user-round" class="size-4 text-brand" aria-hidden="true" />
          <dt class="sr-only">Role</dt>
          <dd>{data.role}</dd>
        </div>
        <span aria-hidden="true" class="opacity-40">·</span>
        <div class="flex items-center gap-1.5">
          <Icon name="lucide:calendar" class="size-4 text-brand" aria-hidden="true" />
          <dt class="sr-only">Year</dt>
          <dd>{data.year}</dd>
        </div>
      </dl>

      {
        data.tags.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-1.5">
            {data.tags.map((t) => (
              <li>
                <Tag>{t}</Tag>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      data.metrics.length > 0 && (
        <dl class="mt-10 grid grid-cols-2 gap-x-8 gap-y-8 border-y border-border py-8 sm:grid-cols-3 lg:grid-cols-4">
          {data.metrics.map((m) => (
            <Stat value={m.value} label={m.label} />
          ))}
        </dl>
      )
    }

    <div class="mt-12 gap-10 lg:grid lg:grid-cols-[minmax(0,1fr)_16rem]">
      <article class="min-w-0 max-w-[var(--container-prose)]">
        <Prose>
          <Content />
        </Prose>

        {
          data.stack.length > 0 && (
            <section class="mt-14 border-t border-border pt-8" aria-label="Technology stack">
              <h2 class="text-sm font-medium uppercase tracking-[0.16em] text-muted-foreground">
                Stack
              </h2>
              <ul class="mt-4 flex flex-wrap gap-1.5">
                {data.stack.map((s) => (
                  <li>
                    <Tag>{s}</Tag>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          data.relatedProject && (
            <Card
              href={`/projects/${data.relatedProject}`}
              interactive
              class="mt-8 flex items-center justify-between gap-4 p-5"
            >
              <span class="flex items-center gap-3">
                <Icon name="lucide:folder-git-2" class="size-5 text-brand" aria-hidden="true" />
                <span>
                  <span class="block text-xs text-muted-foreground">Related project</span>
                  <span class="block font-medium text-foreground">View the project behind this case study</span>
                </span>
              </span>
              <Icon
                name="lucide:arrow-right"
                class="size-4 shrink-0 text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:text-foreground"
                aria-hidden="true"
              />
            </Card>
          )
        }
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-28">
          <Toc headings={headings} />
        </div>
      </aside>
    </div>
  </Container>

  <ContactCTA />
</BaseLayout>

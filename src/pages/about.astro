---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/layout/PageHeader.astro";
import Breadcrumbs from "@/components/layout/Breadcrumbs.astro";
import Section from "@/components/ui/Section.astro";
import Card from "@/components/ui/Card.astro";
import Reveal from "@/components/ui/Reveal.astro";
import ContactCTA from "@/components/sections/ContactCTA.astro";
import { breadcrumbSchema, personSchema } from "@/lib/seo";

const origin = Astro.site!.origin;

const jsonLd = [
  breadcrumbSchema([
    { name: "Home", url: `${origin}/` },
    { name: "About", url: `${origin}/about` },
  ]),
  personSchema(origin),
];

/** Engineering principles — specific, not generic platitudes. */
interface Principle {
  icon: string;
  title: string;
  description: string;
}

const principles: Principle[] = [
  {
    icon: "puzzle",
    title: "Problem solving",
    description:
      "I reach for the constraints before the code — what must stay true, what can give. The hard part is usually framing the problem, not typing the fix.",
  },
  {
    icon: "network",
    title: "Scalable systems",
    description:
      "Clear domain boundaries, idempotent operations and event-driven flows that scale horizontally without quietly drifting out of consistency.",
  },
  {
    icon: "compass",
    title: "Product thinking",
    description:
      "I ask who this serves and what breaks if it's late. The cleanest architecture is worthless if it ships the wrong thing a quarter too slow.",
  },
  {
    icon: "shield-check",
    title: "Ownership",
    description:
      "I design it, build it, wire the pipelines and stay on the hook in production. Pager duty for my own services keeps the designs honest.",
  },
  {
    icon: "users",
    title: "Mentoring",
    description:
      "I level up teammates through design reviews, pairing and written decision records — so the reasoning outlives the person who had it.",
  },
  {
    icon: "book-open",
    title: "Continuous learning",
    description:
      "I read source, not just docs, and prototype unfamiliar tech before it lands in a roadmap. Lately that means going deep on AI engineering.",
  },
];

/** How I work — compact, opinionated working principles. */
const howIWork: string[] = [
  "Write the design doc first; consensus is cheaper before the code exists.",
  "Make the right thing the easy thing — types, lint and CI catch what reviews shouldn't.",
  "Instrument as I build: logs, metrics and traces are part of the feature, not an afterthought.",
  "Optimise for the reader of the code six months from now, including future me.",
  "Ship in small, reversible increments behind flags rather than big-bang releases.",
  "Disagree in the review, commit once it's merged — and write down why.",
];
---

<BaseLayout
  title="About — Engineering Philosophy & How I Work"
  description="A senior full-stack engineer (7+ yrs) across FinTech and Web3 — backend architecture, distributed systems, authentication and identity."
  type="profile"
  jsonLd={jsonLd}
>
  <PageHeader
    eyebrow="About"
    title="How I think about building software"
    lead="A senior full-stack engineer with 7+ years across FinTech and Web3 — backend architecture, distributed systems and authentication, and the interfaces on top of them."
  >
    <Breadcrumbs
      slot="breadcrumbs"
      items={[{ name: "Home", href: "/" }, { name: "About" }]}
    />
  </PageHeader>

  <Section size="wide" spacing="default">
    <div class="max-w-3xl space-y-5 text-base leading-relaxed text-muted-foreground sm:text-lg">
      <p>
        I'm a senior full-stack engineer with 7+ years building production software. I started in
        India in 2019, shipping e-commerce and real-time platforms on the MERN stack at AgileCrew,
        then a custom CMS and a full HR platform at Stead Technologies. In 2022 I moved to Dubai —
        building Ethereum smart contracts and an NFT launchpad at Connectopia, then configurator
        products at Coolshop. Today I own backend architecture for FinTech and Web3 platforms at
        LMNTO, where the systems I work on serve 1.5M+ users. Lately I've been moving deeper into AI
        engineering — building an AI engineering chatbot and an automated PR review system.
      </p>
      <p>
        I'm happiest at the boundary where backend architecture meets a clean interface. My depth is
        in <span class="text-foreground">NestJS, Node.js and Django</span> — event-driven
        microservices that talk over gRPC, OAuth2 / OpenID Connect authentication and identity, and
        the PostgreSQL and Redis underneath. I've spent real time in FinTech and Web3, where KYC/AML,
        digital-asset custody and token lifecycles aren't footnotes — they're the product — so I
        treat correctness and security as features, designed in from the first commit.
      </p>
      <p>
        I like the problems other people find tedious: authentication that has to be exactly right,
        third-party compliance integrations, scaling a service that's outgrowing its assumptions,
        real-time systems that can't drop a message. What follows isn't a résumé — it's the set of
        principles I keep coming back to, whatever the stack or the org chart.
      </p>
    </div>
  </Section>

  <Section
    eyebrow="Principles"
    title="What I optimise for"
    description="Six ideas that show up in every system I've owned — at the architecture board and in the pull request."
    size="wide"
    spacing="compact"
  >
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        principles.map((p, i) => (
          <Reveal delay={i * 80}>
            <Card class="h-full">
              <div class="flex size-11 items-center justify-center rounded-xl border border-border bg-subtle text-brand">
                <Icon name={`lucide:${p.icon}`} class="size-5" aria-hidden="true" />
              </div>
              <h3 class="mt-5 text-lg font-semibold tracking-tight text-foreground">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{p.description}</p>
            </Card>
          </Reveal>
        ))
      }
    </div>
  </Section>

  <Section eyebrow="In practice" title="How I work" size="wide" spacing="compact">
    <ul class="grid gap-x-8 gap-y-px overflow-hidden rounded-2xl border border-border sm:grid-cols-2">
      {
        howIWork.map((item, i) => (
          <Reveal
            delay={i * 70}
            as="li"
            class="flex gap-4 border-b border-border bg-card p-6 last:border-b-0 sm:[&:nth-last-child(2)]:border-b-0"
          >
            <Icon name="lucide:check" class="mt-0.5 size-5 shrink-0 text-brand" aria-hidden="true" />
            <span class="text-sm leading-relaxed text-foreground">{item}</span>
          </Reveal>
        ))
      }
    </ul>
  </Section>

  <ContactCTA />
</BaseLayout>

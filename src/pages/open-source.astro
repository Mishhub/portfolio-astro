---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/layout/PageHeader.astro";
import Breadcrumbs from "@/components/layout/Breadcrumbs.astro";
import Section from "@/components/ui/Section.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Tag from "@/components/ui/Tag.astro";
import Button from "@/components/ui/Button.astro";
import Stat from "@/components/ui/Stat.astro";
import Reveal from "@/components/ui/Reveal.astro";
import ContactCTA from "@/components/sections/ContactCTA.astro";
import ContributionGraph from "@/components/open-source/ContributionGraph.astro";
import { breadcrumbSchema } from "@/lib/seo";
import { PINNED_REPOS, CONTRIBUTION_SUMMARY, GITHUB_PROFILE } from "@/data/open-source";

const origin = Astro.site!.origin;

const crumbs = [{ name: "Home", href: "/" }, { name: "Open Source" }];

const jsonLd = breadcrumbSchema([
  { name: "Home", url: origin },
  { name: "Open Source", url: `${origin}/open-source` },
]);

const title = "Open Source — Pinned Repositories & Contributions";
const description =
  "Pinned repositories and open-source work: event-driven toolkits, auth playgrounds and AI experiments — plus a contribution snapshot and links to my GitHub.";
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <PageHeader
    eyebrow="Open Source"
    title="Building, and sharing how"
    lead="A snapshot of my open-source work — pinned repositories, the languages behind them and a contribution overview. The same rigour I bring to production systems, in public."
  >
    <Breadcrumbs slot="breadcrumbs" items={crumbs} class="mb-2" />
    <div slot="actions" class="mt-8 flex flex-wrap items-center gap-3">
      <Button href={GITHUB_PROFILE} external variant="outline" size="md">
        <Icon name="lucide:github" />
        View GitHub profile
      </Button>
    </div>
  </PageHeader>

  {/* (a) Contribution summary */}
  <Section
    eyebrow="At a glance"
    title="Contribution summary"
    description="Headline numbers from my public work. Illustrative for now — built to be wired to live GitHub data."
    size="wide"
    spacing="compact"
  >
    <Reveal>
      <dl
        class="grid grid-cols-2 gap-x-8 gap-y-8 rounded-2xl border border-border bg-subtle p-7 sm:grid-cols-4 sm:p-8"
      >
        {CONTRIBUTION_SUMMARY.map((s) => <Stat value={s.value} label={s.label} />)}
      </dl>
    </Reveal>
  </Section>

  {/* (b) Pinned repositories */}
  <Section
    eyebrow="Pinned"
    title="Repositories I keep coming back to"
    description="The projects I'm most proud to point at — toolkits, teaching implementations and experiments worth sharing."
    size="wide"
    spacing="compact"
  >
    <ul class="grid gap-5 sm:grid-cols-2">
      {
        PINNED_REPOS.map((repo, i) => (
          <Reveal as="li" delay={i * 80} class="h-full">
            <Card
              href={repo.url === "#" ? undefined : repo.url}
              target={repo.url === "#" ? undefined : "_blank"}
              rel={repo.url === "#" ? undefined : "noopener noreferrer"}
              class="flex h-full flex-col"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex items-center gap-2.5 min-w-0">
                  <Icon
                    name="lucide:github"
                    class="size-5 shrink-0 text-muted-foreground"
                    aria-hidden="true"
                  />
                  <h3 class="truncate font-mono text-base font-semibold tracking-tight text-foreground transition-colors group-hover:text-brand">
                    {repo.name}
                  </h3>
                </div>
                {repo.archived && (
                  <Badge variant="outline" size="sm">
                    Archived
                  </Badge>
                )}
              </div>

              <p class="mt-3 flex-1 text-sm leading-relaxed text-muted-foreground">
                {repo.description}
              </p>

              {repo.topics.length > 0 && (
                <ul class="mt-5 flex flex-wrap gap-1.5">
                  {repo.topics.map((topic) => (
                    <li>
                      <Tag>{topic}</Tag>
                    </li>
                  ))}
                </ul>
              )}

              <div class="mt-5 flex items-center gap-4 text-xs text-muted-foreground">
                <span class="inline-flex items-center gap-1.5">
                  <span
                    class="size-2.5 shrink-0 rounded-full"
                    style={`background-color: ${repo.languageColor};`}
                    aria-hidden="true"
                  />
                  {repo.language}
                </span>
                {typeof repo.stars === "number" && (
                  <span class="inline-flex items-center gap-1">
                    <Icon name="lucide:star" class="size-3.5" aria-hidden="true" />
                    {repo.stars}
                  </span>
                )}
                <Icon
                  name="lucide:arrow-up-right"
                  class="ml-auto size-4 text-foreground/50 transition-all group-hover:translate-x-0.5 group-hover:text-foreground"
                  aria-hidden="true"
                />
              </div>
            </Card>
          </Reveal>
        ))
      }
    </ul>
  </Section>

  {/* (c) Contribution graph placeholder */}
  <Section
    eyebrow="Activity"
    title="Contribution graph"
    description="A GitHub-style heatmap of recent activity. The pattern below is a static placeholder; it's designed to be driven by real contribution data."
    size="wide"
    spacing="compact"
  >
    <Reveal>
      <ContributionGraph />
    </Reveal>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <Button href={GITHUB_PROFILE} external variant="brand" size="md">
        <Icon name="lucide:github" />
        See it live on GitHub
      </Button>
    </div>
  </Section>

  <ContactCTA />
</BaseLayout>
